# FastAPI Configuration
DEBUG=true
API_PORT=8000
API_HOST=0.0.0.0

# Database Configuration
# PostgreSQL connection URL
# Format: postgresql://[user[:password]@][netloc][:port][/dbname]
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/ai_advisor_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_advisor_dev

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# Environment
ENVIRONMENT=development
APP_ENV=development

# AI Configuration
# Optional: Google Gemini API key for AI advice generation
# Leave empty to use local fallback with deterministic advice
# Get key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyA7m8jPUItqwWwcbxY24LrlGdUmwcJBPgA

# Optional: Gemini API endpoint
# Defaults to: https://generativelanguage.googleapis.com/v1/models/gemini-pro:generateContent
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1/models/gemini-pro:generateContent

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Optional: Logging
LOG_LEVEL=INFO

